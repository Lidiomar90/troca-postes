@'
# =========================
# OS / Editor
# =========================
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/

# =========================
# Logs
# =========================
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =========================
# Temp / Cache
# =========================
tmp/
temp/
.cache/
*.tmp

# =========================
# Node
# =========================
node_modules/

# =========================
# Python
# =========================
__pycache__/
*.pyc

# =========================
# Env / secrets
# =========================
.env
.env.*
!.env.example
*.secret.ps1
*.local.ps1

# =========================
# clasp / Apps Script creds
# =========================
.clasprc.json
.clasp-credentials.json

# =========================
# Build / reports
# =========================
dist/
build/
coverage/

# =========================
# Private area
# =========================
privado/*
!privado/.gitkeep

# =========================
# Office temp files
# =========================
~$*.docx
~$*.xlsx
~$*.pptx
'@ | Set-Content -Path ".\.gitignore" -Encoding UTF8